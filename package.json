{
  "name": "axis-companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Companion PWA for the AXIS smart-knob shifter (OTA + tuning + telemetry).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:device": "VITE_TARGET=device vite build && rm -rf dist-device/firmware",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "embed": "node tools/embed-assets.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2",
    "mp4box": "^2.3.0"
  }
}
